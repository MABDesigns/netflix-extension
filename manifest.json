{
  "manifest_version": 2,
  "name": "Netflix Discord RPC",
  "version": "1.0",
  "description": "Sends Netflix playback info to local Discord RPC server",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.netflix.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  }
}